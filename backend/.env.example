# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/luxe

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Stripe (use your TEST keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_CURRENCY=usd
# From `stripe listen` (CLI) or the Stripe Dashboard webhook settings.
# If left blank, the webhook still works in local dev but skips signature verification.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Email (order confirmation to customer + notification to admin).
# Works with any SMTP provider. Example below is Resend (https://resend.com).
# If SMTP_HOST/SMTP_PASS are blank, the app simply skips sending (no errors).
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxx
# "From" must be on a domain you've verified in Resend (use onboarding@resend.dev for quick tests).
EMAIL_FROM=LUXE <orders@yourdomain.com>
# Where admin order notifications are sent.
ADMIN_EMAIL=admin@yourdomain.com
