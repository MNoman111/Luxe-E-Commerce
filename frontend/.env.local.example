# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Stripe publishable TEST key (https://dashboard.stripe.com/test/apikeys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Pakistan manual payment details (JazzCash / Easypaisa / bank transfer).
# Shown to customers who pick that method at checkout. Leave blank to hide the option's details.
NEXT_PUBLIC_PAY_ACCOUNT_NAME=LUXE Store
NEXT_PUBLIC_JAZZCASH_NUMBER=03XX-XXXXXXX
NEXT_PUBLIC_EASYPAISA_NUMBER=03XX-XXXXXXX
NEXT_PUBLIC_BANK_NAME=Meezan Bank
NEXT_PUBLIC_BANK_IBAN=PK00MEZN0000000000000000
